# === Локальная разработка (SQLite + inline worker без Redis) ===
# DATABASE_URL=sqlite:///./data/helmet.db
# INLINE_WORKER=true
# REDIS_URL=redis://127.0.0.1:6379/0

# === VPS (PostgreSQL + Redis + отдельный worker) ===
DATABASE_URL=postgresql://helmet:CHANGE_ME@127.0.0.1:5432/helmet_db
REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUE_NAME=helmet_jobs

API_HOST=0.0.0.0
API_PORT=8000
# Публичный URL для ссылок на видео/снимки (домен или IP VPS)
API_PUBLIC_URL=http://YOUR_VPS_IP:8000

DATA_DIR=/opt/helmet_violation_system/data
INLINE_WORKER=false

# Streamlit на вашем ПК указывает на API VPS:
# HELMET_API_URL=http://YOUR_VPS_IP:8000

# --- Ускорение (CPU VPS: включите все «быстрые» опции ниже) ---
# auto | cpu | 0 | cuda:0
INFERENCE_DEVICE=auto
# Меньше = быстрее (416 или 320 на слабом CPU)
INFERENCE_IMGSZ=416
# Ширина кадра для YOLO (0 = без уменьшения). 640–960 для баланса
INFERENCE_MAX_WIDTH=640
# 1 = каждый кадр, 2–3 = в 2–3 раза быстрее
PROCESS_EVERY_N_FRAMES=2
# FP16 только на GPU
INFERENCE_HALF=true
# Потоки CPU (4–8 на VPS), 0 = по умолчанию
TORCH_NUM_THREADS=4
# false = только нарушения, без рендера mp4 (сильно быстрее)
EXPORT_ANNOTATED_VIDEO=true
# false = пропустить перекодирование ffmpeg в конце
VIDEO_WEB_OPTIMIZE=true
